SECRET_KEY=change-me-in-production
TOKEN_TTL_HOURS=720
STATION_NAME=Winnipeg Nights
MESSENGER_ENCRYPTION_KEYS=
CORS_ORIGINS=
DEBUG=0

# ── TURN (потрібен, щоб групові дзвінки з'єднувались між різними мережами) ──
# Без TURN дзвінок працює лише коли учасники в дружніх до WebRTC мережах.
# Мобільний інтернет / суворі фаєрволи / симетричний NAT вимагають TURN.
# Найпростіше — підняти coturn на цьому ж сервері: bash deploy/install-coturn.sh
# Скрипт сам згенерує логін/пароль і надрукує три рядки нижче — встав їх сюди:
MESSENGER_TURN_URLS=
MESSENGER_TURN_USERNAME=
MESSENGER_TURN_CREDENTIAL=

# Альтернатива: повний JSON списку ICE-серверів (перекриває STUN/TURN вище).
# Для продакшну вкажіть обидва транспорти:
# MESSENGER_TURN_URLS=turn:host:3478?transport=udp,turn:host:3478?transport=tcp
# MESSENGER_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":["turn:host:3478?transport=udp","turn:host:3478?transport=tcp"],"username":"u","credential":"p"}]
